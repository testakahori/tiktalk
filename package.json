{
  "name": "tiktalk",
  "version": "0.1.2",
  "description": "TikTokゲーム配信向け読み上げデスクトップアプリ",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run dev & sleep 2 && electron .",
    "preinstall": "node scripts/generate-icon.js || true",
    "build:renderer": "vite build",
    "build:exe": "npm run build:renderer && electron-builder",
    "build": "npm run build:exe",
    "lint": "eslint src/",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "build": {
    "appId": "com.tiktalk.app",
    "productName": "TikTalk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "core/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python/",
        "to": "python/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ja"
      ],
      "language": "1041",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TikTalk",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "Nicolas0315",
      "repo": "tiktalk"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-log": "^4.4.8",
    "electron-store": "^11.0.2",
    "p-queue": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tiktok-live-connector": "^2.1.1-beta1"
  }
}
